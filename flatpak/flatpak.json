{
  "id": "org.radiotube.housingplanner",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "version": "0.2.0",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "command": "housingplanner",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=/media",
    "--filesystem=/run/media"
  ],
  "modules": [
    {
      "name": "housingplanner",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --frozen --release",
        "install -Dm755 target/release/housingplanner \"${FLATPAK_DEST}/bin/housingplanner\""
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        },
        "cargo-sources.json",
        {
          "type": "inline",
          "dest": ".cargo",
          "dest-filename": "config.toml",
          "contents": "[source.crates-io]\nreplace-with = \"vendored\"\n\n[source.vendored]\ndirectory = \"cargo/vendor\""
        }
      ]
    }
  ]
}
